{
  "manifest_version": 3,
  "name": "Minecraft Server Friends",
  "version": "1.0.0",
  "description": "Track your friends on Minecraft servers",
  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://api.mcsrvstat.us/*",
    "https://minotar.net/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Minecraft Server Friends"
  },
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
